<!DOCTYPE html>
<html lang="zh-Hant">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>記帳本</title>
  <style>
    :root {
      --bg: #f6f7fb;
      --card: #ffffff;
      --text: #1f2937;
      --muted: #6b7280;
      --line: #e5e7eb;
      --primary: #2563eb;
      --primary-dark: #1d4ed8;
      --danger: #dc2626;
      --success: #16a34a;
      --shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
      --radius: 18px;
    }

    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Noto Sans TC", Arial, sans-serif;
      background: linear-gradient(180deg, #eef4ff 0%, var(--bg) 35%, #f8fafc 100%);
      color: var(--text);
    }

    .wrap {
      max-width: 980px;
      margin: 0 auto;
      padding: 32px 18px 48px;
    }

    .hero {
      display: grid;
      gap: 14px;
      margin-bottom: 18px;
    }

    h1 {
      margin: 0;
      font-size: clamp(28px, 4vw, 42px);
      letter-spacing: -0.02em;
    }

    .sub {
      margin: 0;
      color: var(--muted);
      font-size: 15px;
      line-height: 1.7;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 18px;
      align-items: start;
    }

    .card {
      background: var(--card);
      border: 1px solid rgba(229, 231, 235, 0.9);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      padding: 18px;
    }

    .summary {
      display: grid;
      gap: 14px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-bottom: 18px;
    }

    .stat {
      padding: 16px;
      border-radius: 16px;
      background: #f8fafc;
      border: 1px solid var(--line);
    }

    .stat .label {
      color: var(--muted);
      font-size: 13px;
      margin-bottom: 8px;
    }

    .stat .value {
      font-size: 24px;
      font-weight: 700;
      letter-spacing: -0.02em;
    }

    .form {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr auto;
      gap: 10px;
      margin-bottom: 14px;
    }

    input, button, select {
      height: 44px;
      border-radius: 12px;
      border: 1px solid var(--line);
      padding: 0 12px;
      font: inherit;
      background: #fff;
      color: var(--text);
      outline: none;
    }

    input:focus, select:focus {
      border-color: rgba(37, 99, 235, 0.6);
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
    }

    button {
      cursor: pointer;
      border: none;
      background: var(--primary);
      color: white;
      font-weight: 600;
      padding: 0 16px;
      transition: transform .08s ease, background .15s ease;
    }

    button:hover { background: var(--primary-dark); }
    button:active { transform: translateY(1px); }

    .tools {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }

    .tools .ghost {
      background: #eef2ff;
      color: #1e3a8a;
      border: 1px solid #dbeafe;
    }

    .tools .danger {
      background: #fee2e2;
      color: #991b1b;
      border: 1px solid #fecaca;
    }

    .list {
      display: grid;
      gap: 10px;
    }

    .item {
      display: grid;
      grid-template-columns: 88px 1fr auto;
      gap: 10px;
      align-items: center;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: #fff;
    }

    .amt {
      font-weight: 800;
      font-size: 16px;
    }

    .amt.plus { color: var(--success); }
    .amt.minus { color: var(--danger); }

    .meta {
      min-width: 0;
    }

    .meta .title {
      font-weight: 600;
      margin-bottom: 4px;
      word-break: break-word;
    }

    .meta .small {
      color: var(--muted);
      font-size: 13px;
    }

    .delete {
      background: transparent;
      color: var(--danger);
      border: 1px solid #fecaca;
      height: 38px;
      padding: 0 12px;
    }

    .empty {
      padding: 26px 14px;
      text-align: center;
      color: var(--muted);
      border: 1px dashed var(--line);
      border-radius: 14px;
      background: #fafafa;
    }

    .side h2 {
      margin: 0 0 10px;
      font-size: 18px;
    }

    .help {
      color: var(--muted);
      font-size: 14px;
      line-height: 1.7;
    }

    .footer-note {
      margin-top: 12px;
      color: var(--muted);
      font-size: 12px;
    }

    @media (max-width: 860px) {
      .grid { grid-template-columns: 1fr; }
      .summary { grid-template-columns: 1fr; }
      .form { grid-template-columns: 1fr 1fr; }
      .form button { grid-column: span 2; }
      .item { grid-template-columns: 78px 1fr; }
      .item .delete { grid-column: 1 / -1; justify-self: end; }
    }
  </style>
</head>
<body>
  <main class="wrap">
    <section class="hero">
      <h1>記帳本</h1>
      <p class="sub">適合放到 GitHub Pages 的單頁版本。可新增收入/支出、看累積金額，資料會保存在這台瀏覽器的 localStorage。</p>
    </section>

    <section class="summary">
      <div class="stat">
        <div class="label">目前累積總額</div>
        <div class="value" id="total">NT$ 0</div>
      </div>
      <div class="stat">
        <div class="label">收入總和</div>
        <div class="value" id="income">NT$ 0</div>
      </div>
      <div class="stat">
        <div class="label">支出總和</div>
        <div class="value" id="expense">NT$ 0</div>
      </div>
    </section>

    <section class="grid">
      <div class="card">
        <form class="form" id="entryForm">
          <input id="desc" type="text" placeholder="備註，例如：午餐、薪水" required />
          <input id="amount" type="number" step="1" placeholder="金額，例如：500" required />
          <select id="type">
            <option value="income">收入</option>
            <option value="expense">支出</option>
          </select>
          <button type="submit">新增</button>
        </form>

        <div class="tools">
          <button class="ghost" type="button" id="clearDemo">清空全部資料</button>
          <button class="ghost" type="button" id="exportJson">匯出 JSON</button>
          <button class="ghost" type="button" id="exportCsv">匯出 CSV</button>
        </div>

        <div id="list" class="list"></div>
      </div>

      <aside class="card side">
        <h2>使用方式</h2>
        <div class="help">
          1. 先輸入備註、金額，選擇收入或支出。<br />
          2. 新增後會自動更新累積金額。<br />
          3. 關掉頁面再打開，資料仍會留在本機瀏覽器。<br /><br />
          如果之後想升級成「多人共用」、「登入同步」、「每月報表」，這個基礎版可以再往上加 Firebase、Supabase 或 Google Sheets。
        </div>
        <div class="footer-note">
          提醒：localStorage 只存在目前瀏覽器，不會自動同步到其他裝置。
        </div>
      </aside>
    </section>
  </main>

  <script>
    const STORAGE_KEY = 'bookkeeping_entries_v1';

    const form = document.getElementById('entryForm');
    const descEl = document.getElementById('desc');
    const amountEl = document.getElementById('amount');
    const typeEl = document.getElementById('type');
    const listEl = document.getElementById('list');
    const totalEl = document.getElementById('total');
    const incomeEl = document.getElementById('income');
    const expenseEl = document.getElementById('expense');

    function loadEntries() {
      try {
        return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
      } catch {
        return [];
      }
    }

    function saveEntries(entries) {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(entries));
    }

    function money(n) {
      return new Intl.NumberFormat('zh-TW', {
        style: 'currency',
        currency: 'TWD',
        maximumFractionDigits: 0
      }).format(n);
    }

    function todayTime(ts) {
      return new Date(ts).toLocaleString('zh-TW', {
        year: 'numeric', month: '2-digit', day: '2-digit',
        hour: '2-digit', minute: '2-digit'
      });
    }

    function calc(entries) {
      const income = entries.filter(x => x.type === 'income').reduce((s, x) => s + x.amount, 0);
      const expense = entries.filter(x => x.type === 'expense').reduce((s, x) => s + x.amount, 0);
      const total = income - expense;
      return { income, expense, total };
    }

    function render() {
      const entries = loadEntries().sort((a, b) => b.createdAt - a.createdAt);
      const { income, expense, total } = calc(entries);

      totalEl.textContent = money(total);
      incomeEl.textContent = money(income);
      expenseEl.textContent = money(expense);

      if (entries.length === 0) {
        listEl.innerHTML = '<div class="empty">目前還沒有任何記錄，先新增一筆吧。</div>';
        return;
      }

      listEl.innerHTML = entries.map(entry => `
        <article class="item">
          <div class="amt ${entry.type === 'income' ? 'plus' : 'minus'}">
            ${entry.type === 'income' ? '+' : '-'}${money(entry.amount).replace('NT$', '').trim()}
          </div>
          <div class="meta">
            <div class="title">${escapeHtml(entry.desc)}</div>
            <div class="small">${entry.type === 'income' ? '收入' : '支出'} · ${todayTime(entry.createdAt)}</div>
          </div>
          <button class="delete" type="button" data-id="${entry.id}">刪除</button>
        </article>
      `).join('');

      document.querySelectorAll('.delete').forEach(btn => {
        btn.addEventListener('click', () => {
          const id = btn.getAttribute('data-id');
          const next = loadEntries().filter(x => x.id !== id);
          saveEntries(next);
          render();
        });
      });
    }

    function escapeHtml(str) {
      return String(str)
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#39;');
    }

    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const desc = descEl.value.trim();
      const amount = Number(amountEl.value);
      const type = typeEl.value;

      if (!desc || !Number.isFinite(amount) || amount <= 0) return;

      const entries = loadEntries();
      entries.push({
        id: crypto.randomUUID(),
        desc,
        amount: Math.round(amount),
        type,
        createdAt: Date.now()
      });

      saveEntries(entries);
      form.reset();
      descEl.focus();
      render();
    });

    document.getElementById('clearDemo').addEventListener('click', () => {
      if (confirm('確定要清空所有資料嗎？')) {
        localStorage.removeItem(STORAGE_KEY);
        render();
      }
    });

    document.getElementById('exportJson').addEventListener('click', () => {
      const entries = loadEntries();
      const blob = new Blob([JSON.stringify(entries, null, 2)], { type: 'application/json' });
      downloadBlob(blob, 'bookkeeping.json');
    });

    document.getElementById('exportCsv').addEventListener('click', () => {
      const entries = loadEntries();
      const rows = [
        ['date', 'type', 'description', 'amount'],
        ...entries.map(x => [new Date(x.createdAt).toISOString(), x.type, x.desc, x.amount])
      ];
      const csv = rows.map(r => r.map(v => '"' + String(v).replaceAll('"', '""') + '"').join(',')).join('\n');
      const blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
      downloadBlob(blob, 'bookkeeping.csv');
    });

    function downloadBlob(blob, filename) {
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = filename;
      document.body.appendChild(a);
      a.click();
      a.remove();
      URL.revokeObjectURL(url);
    }

    render();
  </script>
</body>
</html>
